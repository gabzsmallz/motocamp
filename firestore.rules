rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Each user can only read/write their own site interaction data
    match /users/{userId}/data/{doc} {
      allow read, write: if request.auth != null
        && request.auth.uid == userId;
    }

    // Suggestions — must be signed in to submit (prevents anonymous spam),
    // 1000-char limit, only admin can read/moderate
    match /suggestions/{suggestionId} {
      allow create: if request.auth != null
        && request.resource.data.text == null || request.resource.data.description.size() <= 2000;
      allow read, update, delete: if request.auth != null
        && request.auth.token.email == "gabssmall@gmail.com";
    }

    // Community-approved campsites — public read, admin-only write
    match /campsites/{id} {
      allow read: if true;
      allow write: if request.auth != null
        && request.auth.token.email == "gabssmall@gmail.com";
    }

    // Community ratings — public read, authenticated users write only their own
    match /ratings/{siteId} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    // Trip reports / comments — public read, authenticated post,
    // users delete own + admin deletes any, 1000-char limit
    match /comments/{siteId}/posts/{postId} {
      allow read: if true;
      allow create: if request.auth != null
        && request.resource.data.uid == request.auth.uid
        && request.resource.data.text.size() > 0
        && request.resource.data.text.size() <= 1000;
      allow delete: if request.auth != null
        && (resource.data.uid == request.auth.uid
            || request.auth.token.email == "gabssmall@gmail.com");
    }
  }
}
