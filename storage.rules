rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    // Campsite photos — public read, admin-only upload
    match /campsite-photos/{siteId}/{fileName} {
      allow read: if true;
      allow write: if request.auth != null
        && request.auth.token.email == "gabssmall@gmail.com";
    }
  }
}
