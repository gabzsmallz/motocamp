rules_version = '2';
// Deploy with: firebase deploy --only storage
service firebase.storage {
  match /b/{bucket}/o {
    // Campsite photos — anyone can read, only admin can upload
    match /campsite-photos/{siteId}/{fileName} {
      allow read: if true;
      allow write: if request.auth != null
        && request.auth.token.email == "YOUR_ADMIN_EMAIL";
    }
  }
}
